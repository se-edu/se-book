@startuml
skinparam backgroundColor transparent
skinparam shadowing false
skinparam defaultTextAlignment center
skinparam rectangle {
  BackgroundColor #FDFDFD
  BorderColor #333333
  roundCorner 8
}
top to bottom direction
rectangle "Unstructured\nprogram" as a
rectangle "Modular\nmonolith" as b
rectangle "Client and\nserver" as c
rectangle "Microservices" as d
a --> b : needs clearer\nresponsibilities
b --> c : needs shared\nlive data
c --> d : teams need\nindependent releases
@enduml
